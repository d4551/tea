APP_NAME=Leaves of the Fallen Kingdom
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=3000
DEFAULT_LOCALE=en-US
PUBLIC_ASSET_PREFIX=/public
IMAGES_ASSET_PREFIX=/assets
RMMZ_PACK_PREFIX=/rmmz-pack
PUBLIC_ASSET_DIR=public
IMAGES_ASSET_DIR=assets
RMMZ_PACK_DIR=LOTFK_RMMZ_Agentic_Pack
PLAYABLE_GAME_MOUNT_PATH=/game
PLAYABLE_GAME_SOURCE_DIRECTORY=public/game
API_DOCS_PATH=/docs
APP_THEME=silk
MAX_CONTENT_WIDTH_CLASS=max-w-6xl
SESSION_COOKIE_NAME=lotfk_session
SESSION_MAX_AGE_SECONDS=604800
GAME_SESSION_STORE=prisma
GAME_DEFAULT_SCENE_ID=teaHouse
GAME_SESSION_TTL_MS=3600000
GAME_TICK_MS=16
GAME_SESSION_PERSIST_INTERVAL_MS=250
GAME_SAVE_COOLDOWN_MS=2500
GAME_MAX_MOVE_PER_TICK=12
GAME_MAX_COMMANDS_PER_TICK=6
GAME_MAX_INTERACTIONS_PER_TICK=3
GAME_MAX_CHAT_COMMANDS_PER_WINDOW=8
GAME_CHAT_RATE_LIMIT_WINDOW_MS=4000
GAME_MAX_CHAT_MESSAGE_LENGTH=500
GAME_VIEWPORT_WIDTH=640
GAME_VIEWPORT_HEIGHT=360
GAME_HUD_POLL_INTERVAL_MS=500
GAME_HUD_RETRY_MS=2000
GAME_SESSION_PURGE_INTERVAL_MS=60000
GAME_SESSION_RESUME_WINDOW_MS=604800000
GAME_COMMAND_SEND_INTERVAL_MS=50
GAME_COMMAND_TTL_MS=60000
GAME_SOCKET_RECONNECT_DELAY_MS=1000
GAME_RESTORE_REQUEST_TIMEOUT_MS=5000
GAME_RESTORE_MAX_ATTEMPTS=2
ORACLE_REQUIRE_SESSION=false
ORACLE_RESPONSE_DELAY_MS=180
ORACLE_MAX_QUESTION_LENGTH=240
ORACLE_ANSWER_HASH_MULTIPLIER=7
DATABASE_URL=file:./prisma/dev.db
AI_WARMUP_ON_BOOT=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ENABLED=true
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_VISION_MODEL=llava
OLLAMA_TIMEOUT_MS=30000
OLLAMA_KEEP_ALIVE_MS=300000
AI_PREFERRED_PROVIDER=auto
AI_CAPABILITY_REFRESH_INTERVAL_MS=60000
AI_TRANSFORMERS_CACHE_DIR=./.cache/hf-models
AI_TRANSFORMERS_LOCAL_MODEL_PATH=./.cache/hf-models
AI_ALLOW_REMOTE_MODELS=true
AI_ALLOW_LOCAL_MODELS=true
AI_ONNX_THREAD_COUNT=2
AI_ONNX_PROXY_ENABLED=false
AI_LOCAL_SENTIMENT_MODEL=Xenova/distilbert-base-uncased-finetuned-sst-2-english
AI_LOCAL_TEXT_GENERATION_MODEL=Xenova/gpt2
AI_LOCAL_NPC_DIALOGUE_MODEL=Xenova/gpt2
AI_LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
AI_LOCAL_SPEECH_TO_TEXT_MODEL=onnx-community/whisper-tiny.en
AI_LOCAL_TEXT_TO_SPEECH_MODEL=Xenova/speecht5_tts
AI_LOCAL_STT_ENABLED=true
AI_LOCAL_TTS_ENABLED=true
AI_LOCAL_EMBEDDINGS_ENABLED=true
AI_AUDIO_INPUT_SAMPLE_RATE_HZ=16000
AI_AUDIO_UPLOAD_MAX_BYTES=6291456
AI_LOCAL_TTS_SPEAKER_EMBEDDINGS=https://huggingface.co/datasets/Xenova/transformers.js-docs/resolve/main/speaker_embeddings.bin

APP_NAME=Leaves of the Fallen Kingdom
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=3000
DEFAULT_LOCALE=en-US
PUBLIC_ASSET_PREFIX=/public
IMAGES_ASSET_PREFIX=/assets
RMMZ_PACK_PREFIX=/rmmz-pack
PUBLIC_ASSET_DIR=public
IMAGES_ASSET_DIR=assets
RMMZ_PACK_DIR=LOTFK_RMMZ_Agentic_Pack
PLAYABLE_GAME_MOUNT_PATH=/game
PLAYABLE_GAME_SOURCE_DIRECTORY=public/game
GAME_DEFAULT_SCENE_ID=teaHouse
API_DOCS_PATH=/docs
APP_THEME=silk
MAX_CONTENT_WIDTH_CLASS=max-w-6xl
SESSION_COOKIE_NAME=lotfk_session
SESSION_COOKIE_VALUE=active
ORACLE_REQUIRE_SESSION=false
ORACLE_RESPONSE_DELAY_MS=180
ORACLE_MAX_QUESTION_LENGTH=240
ORACLE_ANSWER_HASH_MULTIPLIER=7
SPRITE_SOURCE_DIR=assets/source
SPRITE_OUTPUT_DIR=assets/images/sprites
SPRITE_FLOOD_FILL_TOLERANCE=40
SPRITE_INTERIOR_GRAY_SPREAD_THRESHOLD=8
SPRITE_INTERIOR_GRAY_LUMINANCE_MIN=120
SPRITE_INTERIOR_GRAY_LUMINANCE_MAX=230
SPRITE_AI_MODEL=Xenova/modnet
SPRITE_SOURCE_CHA_JIANG=cha-jiang-source.png
SPRITE_OUTPUT_CHA_JIANG=cha-jiang-sprite.png
SPRITE_SOURCE_NPC_SHEET=npc-sprites-source.png
SPRITE_OUTPUT_NPC_SHEET=npc-sprites.png
DATABASE_URL=file:./prisma/dev.db
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ENABLED=true
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_VISION_MODEL=llava
OLLAMA_TIMEOUT_MS=30000
OLLAMA_KEEP_ALIVE_MS=300000
AI_PREFERRED_PROVIDER=auto
AI_CAPABILITY_REFRESH_INTERVAL_MS=60000

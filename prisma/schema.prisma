generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
}

model OracleInteraction {
  id        String   @id @default(cuid())
  prompt    String
  sentiment String
  fortune   String
  createdAt DateTime @default(now())
}

model GameSession {
  id          String   @id @default(cuid())
  ownerSessionId String @default("anonymous")
  seed        Int
  locale      String   @default("en-US")
  sceneId     String   @default("teaHouse")
  state       Json
  stateVersion Int     @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expiresAt   DateTime
  progress    PlayerProgress?
}

model BuilderProject {
  id                     String                 @id
  state                  Json
  checksum               String
  version                Int                    @default(1)
  createdBy              String                 @default("system")
  updatedBy              String                 @default("system")
  source                 String                 @default("builder-service-seed")
  latestReleaseVersion   Int                    @default(0)
  publishedReleaseVersion Int?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  releases               BuilderProjectRelease[]
}

model BuilderProjectRelease {
  id             String         @id @default(cuid())
  projectId      String
  project        BuilderProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  releaseVersion Int
  checksum       String
  state          Json
  createdAt      DateTime       @default(now())

  @@unique([projectId, releaseVersion])
}

model PlayerProgress {
  id            String      @id @default(cuid())
  sessionId     String      @unique
  session       GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  xp            Int         @default(0)
  level         Int         @default(1)
  visitedScenes Json
  interactions  Json
  updatedAt     DateTime    @updatedAt
}

model AiGenerationLog {
  id         String   @id @default(cuid())
  sessionId  String?
  provider   String
  model      String
  capability String
  prompt     String
  response   String
  durationMs Int
  locale     String   @default("en-US")
  createdAt  DateTime @default(now())
}

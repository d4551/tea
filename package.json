{
  "name": "lotfk-tea-house",
  "description": "SSR-first game runtime, builder workspace, and AI-enabled game platform built on Bun and TypeScript.",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "audit:security": "bun audit",
    "docs:archive": "bun run scripts/archive-docs.ts",
    "docs:check": "bun run scripts/docs-surface-check.ts",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "dev": "bun run scripts/dev.ts",
    "start": "bun run build:assets && bun src/server.ts",
    "build:assets": "bun run scripts/build-assets.ts",
    "dependency:drift": "bun run scripts/dependency-drift-check.ts",
    "setup": "bun run scripts/setup.ts",
    "doctor": "bun run scripts/doctor.ts",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "playwright test",
    "prisma:generate": "bunx --bun prisma generate",
    "prisma:migrate": "bun run scripts/prisma-migrate.ts",
    "verify": "bun run build:assets && bun run dependency:drift && bun run docs:check && bun run lint && bun run typecheck && bun test"
  },
  "dependencies": {
    "@elysiajs/openapi": "1.4.14",
    "@huggingface/transformers": "3.8.1",
    "@libsql/client": "0.17.0",
    "@prisma/adapter-libsql": "7.5.0",
    "@prisma/client": "7.5.0",
    "elysia": "1.4.27",
    "htmx-ext-sse": "2.2.4",
    "htmx.org": "2.0.8",
    "lotfk-game-contracts": "workspace:*",
    "lotfk-seeded-prng": "workspace:*",
    "pixi.js": "8.17.0",
    "playwright": "1.58.2",
    "sharp": "0.34.5",
    "sqlite-vec": "0.1.7-alpha.2",
    "three": "0.183.2"
  },
  "trustedDependencies": [
    "onnxruntime-node",
    "protobufjs",
    "sharp"
  ],
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@biomejs/biome": "2.4.7",
    "@playwright/test": "1.58.2",
    "@tailwindcss/cli": "4.2.1",
    "@types/bun": "1.3.10",
    "@types/three": "0.183.1",
    "daisyui": "5.5.19",
    "prisma": "7.5.0",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  }
}

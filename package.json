{
  "name": "lotfk-tea-house",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "format": "biome format . --write",
    "format:check": "biome format .",
    "dev": "bun run scripts/dev.ts",
    "start": "bun run build:assets && bun src/server.ts",
    "build:assets": "bun run scripts/build-assets.ts",
    "process:sprites": "bun run scripts/process-sprites.ts",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prisma:generate": "prisma generate",
    "verify": "bun run build:assets && bun run lint && bun run typecheck && bun test"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/static": "1.4.7",
    "@elysiajs/swagger": "1.3.1",
    "@huggingface/transformers": "3.8.1",
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-libsql": "^7.4.2",
    "@prisma/client": "7.4.2",
    "elysia": "1.4.27",
    "htmx.org": "2.0.8",
    "lotfk-game-contracts": "workspace:*",
    "lotfk-seeded-prng": "workspace:*",
    "pixi.js": "^8.16.0",
    "sharp": "0.34.5",
    "three": "^0.183.2"
  },
  "trustedDependencies": [
    "onnxruntime-node",
    "protobufjs",
    "sharp"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tailwindcss/cli": "4.2.1",
    "@types/bun": "1.3.10",
    "@types/three": "^0.183.1",
    "daisyui": "5.5.19",
    "dotenv": "^17.3.1",
    "prisma": "7.4.2",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  }
}
